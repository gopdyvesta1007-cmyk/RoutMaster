<Window x:Class="RouteMaster.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RouteMaster" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#EABC8C">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#723B1B" Padding="10">
            <Grid>
                <TextBlock Text="ROUTEMASTER" FontSize="18" FontWeight="Bold" Foreground="#EABC8C"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock x:Name="UserInfoText" Foreground="#EABC8C" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Button x:Name="LogoutButton" Content="Выйти" Background="Transparent" BorderBrush="#EABC8C" BorderThickness="1" Foreground="#EABC8C" Padding="10,5" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Все заказы" Background="#EABC8C" Foreground="#723B1B" FontWeight="Bold">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBox x:Name="SearchBox" Width="200" Margin="5" Padding="8" Background="White" BorderBrush="#995108" BorderThickness="1"/>
                        <Button x:Name="SearchButton" Content="Поиск" Background="#723B1B" Foreground="White" Padding="15,8" Margin="5" Cursor="Hand"/>
                        <Button x:Name="ClearButton" Content="Сброс" Background="Transparent" BorderBrush="#723B1B" BorderThickness="1" Foreground="#723B1B" Padding="15,8" Margin="5" Cursor="Hand"/>
                    </WrapPanel>

                    <DataGrid x:Name="AllOrdersGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" Background="#EABC8C">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="120"/>
                            <DataGridTextColumn Header="Клиент" Binding="{Binding ClientName}" Width="150"/>
                            <DataGridTextColumn Header="Откуда" Binding="{Binding PickupCity}" Width="120"/>
                            <DataGridTextColumn Header="Куда" Binding="{Binding DeliveryCity}" Width="120"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding CurrentStatus}" Width="120"/>
                            <DataGridTemplateColumn Header="Прогресс" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ProgressBar Value="{Binding Progress}" Maximum="100" Height="10" Background="#E0C8A0" Foreground="#723B1B"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Действия" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Детали" Tag="{Binding}" Click="ViewDetails_Click" Background="#723B1B" Foreground="White" Padding="8,3" Cursor="Hand"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Мои заказы" Background="#EABC8C" Foreground="#723B1B" FontWeight="Bold">
                <DataGrid x:Name="MyOrdersGrid" Margin="10" AutoGenerateColumns="False" IsReadOnly="True" Background="#EABC8C">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="№ заказа" Binding="{Binding OrderNumber}" Width="120"/>
                        <DataGridTextColumn Header="Откуда" Binding="{Binding PickupCity}" Width="120"/>
                        <DataGridTextColumn Header="Куда" Binding="{Binding DeliveryCity}" Width="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding CurrentStatus}" Width="120"/>
                        <DataGridTemplateColumn Header="Прогресс" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ProgressBar Value="{Binding Progress}" Maximum="100" Height="10" Background="#E0C8A0" Foreground="#723B1B"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Действия" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Детали" Tag="{Binding}" Click="ViewDetails_Click" Background="#723B1B" Foreground="White" Padding="8,3" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="#723B1B" Padding="5">
            <TextBlock x:Name="StatusText" Foreground="#EABC8C" FontSize="11"/>
        </Border>
    </Grid>
</Window>