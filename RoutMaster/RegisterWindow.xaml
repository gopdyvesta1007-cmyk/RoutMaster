<Window x:Class="RouteMaster.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="450" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Background="#1976D2">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280" Margin="20">
                <TextBlock Text="Регистрация" FontSize="22" FontWeight="Bold" 
                          Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,20"/>

                <TextBox x:Name="FullNameBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>
                <TextBox x:Name="EmailBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>
                <TextBox x:Name="PhoneBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>
                <PasswordBox x:Name="PasswordBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>
                <PasswordBox x:Name="ConfirmPasswordBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>

                <Button x:Name="RegisterBtn" Content="Зарегистрироваться" Background="#4CAF50" 
                        FontSize="14" Padding="12" Margin="0,15,0,5" Foreground="White"/>

                <Button x:Name="CancelBtn" Content="Отмена" Background="Transparent" 
                        Foreground="White" BorderBrush="White" BorderThickness="1" Padding="12" Margin="0,5"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>