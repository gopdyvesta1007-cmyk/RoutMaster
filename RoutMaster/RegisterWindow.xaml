<Window x:Class="RouteMaster.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация" Height="550" Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#EABC8C">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="РЕГИСТРАЦИЯ" FontSize="22" FontWeight="Bold" Foreground="#723B1B" HorizontalAlignment="Center" Margin="0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="350">
            <StackPanel Margin="0,20">
                <TextBox x:Name="FullNameBox" Margin="0,8" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
                <TextBox x:Name="EmailBox" Margin="0,8" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
                <TextBox x:Name="PhoneBox" Margin="0,8" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
                <PasswordBox x:Name="PasswordBox" Margin="0,8" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
                <PasswordBox x:Name="ConfirmPasswordBox" Margin="0,8" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Margin="0,20">
            <Button x:Name="RegisterBtn" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Background="#723B1B" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Cursor="Hand"/>
            <Button x:Name="CancelBtn" Content="ОТМЕНА" Background="Transparent" Foreground="#723B1B" BorderBrush="#723B1B" BorderThickness="2" FontSize="14" FontWeight="Bold" Height="40" Margin="0,10" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>