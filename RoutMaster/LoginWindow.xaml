<Window x:Class="RouteMaster.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RouteMaster - Вход" Height="350" Width="400"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#1976D2">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
            <TextBlock Text="RouteMaster" FontSize="28" FontWeight="Bold" 
                      Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <TextBox x:Name="EmailBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>
            <PasswordBox x:Name="PasswordBox" FontSize="14" Background="White" Margin="0,8" Padding="8"/>

            <TextBlock x:Name="ErrorText" Foreground="#FF6B6B" FontSize="12" Margin="0,5" Visibility="Collapsed"/>

            <Button x:Name="LoginButton" Content="Войти" Background="#FF5722" 
                    FontSize="14" Padding="12" Margin="0,15,0,5" Foreground="White"/>

            <Button x:Name="RegisterButton" Content="Регистрация" Background="Transparent" 
                    Foreground="White" BorderBrush="White" BorderThickness="1" Padding="12" Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>