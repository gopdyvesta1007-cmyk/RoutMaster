<Window x:Class="RouteMaster.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RouteMaster" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#EABC8C">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ROUTEMASTER" FontSize="28" FontWeight="Bold" Foreground="#723B1B" HorizontalAlignment="Center" Margin="0,20"/>

        <StackPanel Grid.Row="1" Margin="0,30">
            <TextBox x:Name="EmailBox" Margin="0,10" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,10" Padding="10" FontSize="14" Background="White" BorderBrush="#995108" BorderThickness="2"/>
            <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="12" Margin="0,5" Visibility="Collapsed"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,20">
            <Button x:Name="LoginButton" Content="ВОЙТИ" Background="#723B1B" Foreground="White" FontSize="14" FontWeight="Bold" Height="40" Cursor="Hand"/>
            <Button x:Name="RegisterButton" Content="РЕГИСТРАЦИЯ" Background="Transparent" Foreground="#723B1B" BorderBrush="#723B1B" BorderThickness="2" FontSize="14" FontWeight="Bold" Height="40" Margin="0,10" Cursor="Hand"/>
        </StackPanel>

        <TextBlock Grid.Row="3" Text="© 2024 RouteMaster" FontSize="10" Foreground="#995108" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
    </Grid>
</Window>